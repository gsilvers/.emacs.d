12:53:42 997                                                DENSE_RANK()
12:53:42 998                                                OVER(PARTITION BY safe_number, h.contributor || h.account_number
12:53:42 999                                                     ORDER BY
12:53:42 1000                                                      h.date_reported DESC, h.yyyy_mm DESC, h.balance DESC
12:53:42 1001                                                ) tls
12:53:42 1002                                                FROM
