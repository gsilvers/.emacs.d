12:53:43 1110                                     -(group_sums.balance_1_30 / DECODE(group_sums.balance_total,0,1,group_sums.balance_total)) * 100)
12:53:43 1111                                     -(group_sums.balance_31_60 / DECODE(group_sums.balance_total,0,1,group_sums.balance_total)) * 100
12:53:43 1112                                     -(group_sums.balance_61_90 / DECODE(group_sums.balance_total,0,1,group_sums.balance_total)) * 100,2)
12:53:43 1113                           ELSE 0 END AS pct_balance_91plus
12:53:43 1114                  from group_sums;
12:53:43 1115        END p_get_tpd_group_industries;
