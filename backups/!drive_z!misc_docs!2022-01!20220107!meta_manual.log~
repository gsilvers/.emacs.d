12:53:43 1318                PAYMENT_HISTORY  his ON (V12.YYYY_MM = his.YYYY_MM and his.safe_number = i_safe_number)
12:53:43 1319                where last_n between lower_lim and upper_lim
12:53:43 1320                order by v12.yyyy_mm, last_n;
12:53:43 1321
12:53:43 1322            select sic_four_digits , to_char(add_months(to_date(max_yyyy_mm, 'YYYY-MM'),-12)-1,'YYYY-MM') as l_down_time_limit
12:53:43 1323              into l_sic_4_digits , l_down_time_limit
12:53:43 1324            from company
12:53:43 1325            where safe_number = i_safe_number;
12:53:43 1326
