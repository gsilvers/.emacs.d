12:53:43 1172        L_MONTHS_AGO NUMBER:=6;
12:53:43 1173        l_limit_date varchar2(7) := TO_CHAR(ADD_MONTHS(SYSDATE,-7),'YYYY-MM');
12:53:43 1174     Begin
