12:53:43 1008   PROCEDURE p_get_monthly_total_balance(i_safe_number  IN VARCHAR2
12:53:43 1009                                             ,i_rows_number  NUMBER
12:53:43 1010                                             ,o_cursor       OUT SYS_REFCURSOR
12:53:43 1011                                             ,o_cursor_trend OUT SYS_REFCURSOR) IS
12:53:43 1012          l_trend_value NUMBER; --value is useless
12:53:43 1013        BEGIN
12:53:43 1014
12:53:43 1015          OPEN o_cursor FOR
12:53:43 1016            SELECT *
12:53:43 1017            FROM (SELECT ph.balance_total AS balance
12:53:43 1018                        ,vl.yyyy_mm       AS balance_date
12:53:43 1019                  FROM v_last_6months vl
12:53:43 1020                  LEFT JOIN (SELECT ph.balance_total
12:53:43 1021                                  ,ph.yyyy_mm
12:53:43 1022                            FROM payment_history ph
