12:53:43 1099                  , CASE WHEN group_sums.balance_total<>0 THEN
12:53:43 1100                          ROUND((group_sums.balance_1_30 / DECODE(group_sums.balance_total,0,1,group_sums.balance_total)) * 100,2)
12:53:43 1101                          ELSE 0 END AS pct_balance_1_30
12:53:43 1102                  , CASE WHEN group_sums.balance_total<>0 THEN
