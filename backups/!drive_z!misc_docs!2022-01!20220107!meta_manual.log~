12:53:43 1208        THEN
12:53:43 1209            Raise_Application_Error(-20001,'Both dimensions _to_compare [I_State,i_SIC] must be set.');
12:53:43 1210        END IF;
12:53:43 1211
12:53:43 1212        -- BY STATE
12:53:43 1213        -- BY STATE UCC
