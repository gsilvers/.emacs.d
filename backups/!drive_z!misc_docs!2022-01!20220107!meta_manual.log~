12:53:43 856     PROCEDURE get_dbt_compare(i_state_to_compare IN VARCHAR2
12:53:43 857                              ,i_sic_to_compare   IN VARCHAR2
12:53:43 858                              , --I_BusinessType_to_compare in varchar2,--not sure for use
12:53:43 859                               o_state_cursor     OUT SYS_REFCURSOR
12:53:43 860                              ,o_industry_cursor  OUT SYS_REFCURSOR) IS
12:53:43 861       l_months_ago NUMBER := 6;
12:53:43 862       l_limit_date VARCHAR2(7) := to_char(add_months(SYSDATE
12:53:43 863                                                     ,-1 * l_months_ago)
12:53:43 864                                          ,'YYYY-MM');
12:53:43 865     BEGIN
12:53:43 866
12:53:43 867       IF (i_state_to_compare IS NULL OR i_sic_to_compare IS NULL) THEN
12:53:43 868         raise_application_error(-20001
12:53:43 869                                ,'Both dimensions _to_compare [I_State,i_SIC] must be set.');
12:53:43 870       END IF;
12:53:43 871
12:53:43 872       -- BY STATE
12:53:43 873       OPEN o_state_cursor FOR
12:53:43 874         SELECT months.yyyy
12:53:43 875               ,months.mm
12:53:43 876               , CASE i_sic_to_compare
12:53:43 877                   WHEN C_NON_CLASSIFIABLE_SIC THEN
12:53:43 878                     NULL
12:53:43 879                   ELSE
12:53:43 880                     round(core.value, 2)
12:53:43 881                 END                        AS value
12:53:43 882         FROM v_last_6months months
12:53:43 883         LEFT OUTER JOIN
12:53:43 884         -- core data extract here:
12:53:43 885          (SELECT su.yyyy_mm
12:53:43 886                 ,round(SUM(total_value) / SUM(total_companies)) AS VALUE
12:53:43 887           FROM cs_stats_dbt su
12:53:43 888           WHERE su.yyyy_mm >= l_limit_date
12:53:43 889                 AND su.state_code = i_state_to_compare
12:53:43 890           GROUP BY yyyy_mm) core
12:53:43 891         ON (core.yyyy_mm = months.yyyy_mm)
12:53:43 892         ORDER BY months.yyyy_mm ASC;
12:53:43 893
12:53:43 894       -- by SIC
12:53:43 895       OPEN o_industry_cursor FOR
12:53:43 896         SELECT months.yyyy
12:53:43 897               ,months.mm
12:53:43 898               ,CASE i_sic_to_compare
12:53:43 899                   WHEN C_NON_CLASSIFIABLE_SIC THEN
12:53:43 900                     NULL
12:53:43 901                   ELSE
12:53:43 902                     core.value
12:53:43 903                 END                        AS value
12:53:43 904         FROM v_last_6months months
12:53:43 905         LEFT OUTER JOIN
12:53:43 906         -- core data extract here:
12:53:43 907          (SELECT su.yyyy_mm
12:53:43 908                 ,round(SUM(total_value) / SUM(total_companies)) AS VALUE
12:53:43 909           FROM cs_stats_dbt su
12:53:43 910           WHERE su.yyyy_mm >= l_limit_date
12:53:43 911                 AND su.sic = i_sic_to_compare
12:53:43 912           GROUP BY yyyy_mm) core
12:53:43 913         ON (core.yyyy_mm = months.yyyy_mm)
12:53:43 914         ORDER BY months.yyyy_mm ASC;
12:53:43 915
12:53:43 916     END get_dbt_compare;
