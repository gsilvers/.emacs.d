12:53:43 885    procedure p_balance_TREND
12:53:43 886            /******************************************************************************
12:53:43 887            **          Name: p_balance_TREND
12:53:43 888            **          Desc: Calculation of BALANCE trend (over last 6 months)
12:53:43 889            **
12:53:43 890            **          Return values: CURSOR with trend line values or just trend_Value as number
12:53:43 891            **          Author: Bartlomiej Sus / SMT
12:53:43 892            **          Date:   2016-01-14
12:53:43 893            *******************************************************************************
12:53:43 894            **          Change History
12:53:43 895            *******************************************************************************
12:53:43 896            **          Date:       Author:       Description:
12:53:43 897            **          2016-01-16 Bartek Sus   inital code copy from p_dbt_trend
12:53:43 898            *******************************************************************************/
12:53:43 899
12:53:43 900          (I_safe_number varchar2,
12:53:43 901            i_with_cursor in char default 'N',
12:53:43 902            O_CURSOR OUT SYS_REFCURSOR,
12:53:43 903            o_trend_Value out number
12:53:43 904          )
12:53:43 905          is
12:53:43 906
12:53:43 907            L_LAST3_SET NUMBER;
12:53:43 908            L_LAST5_SET NUMBER;
12:53:43 909
12:53:43 910            chart_A number;
12:53:43 911            chart_B NUMBER;
12:53:43 912          begin
12:53:43 913
12:53:43 914               begin
12:53:43 915             -- checking how many non-empty values we have
12:53:43 916              WITH LATEST AS (
12:53:43 917                SELECT DECODE(CPH.BALANCE_total,NULL,0,1) AS NON_EMPTY_BALANCE,
12:53:43 918                      CPH.BALANCE_TOTAL AS BALANCE,
12:53:43 919                      v6.YYYY_MM,
12:53:43 920                       row_number() over (order by v6.yyyy_mm desc) as rn
12:53:43 921                FROM  (SELECT YYYY_MM, LAST_N_DESC AS LAST_N
12:53:43 922                        FROM V_LAST_6MONTHS V6
12:53:43 923                        ORDER BY YYYY_MM DESC) V6
12:53:43 924                      LEFT OUTER JOIN   PAYMENT_HISTORY  CPH ON (V6.YYYY_MM = CPH.YYYY_MM AND CPH.SAFE_NUMBER = I_SAFE_NUMBER)
12:53:43 925                WHERE (LAST_N<=6)
12:53:43 926              )
12:53:43 927              SELECT
12:53:43 928                 SUM(CASE WHEN RN<=3 THEN NON_EMPTY_BALANCE END) NON_EMPTY_BALANCE_LAST3,
12:53:43 929                 SUM(CASE WHEN RN<=5 THEN NON_EMPTY_BALANCE END) NON_EMPTY_BALANCE_LAST5
12:53:43 930               INTO
12:53:43 931                 l_last3_set, l_last5_set
12:53:43 932              FROM latEST ;
12:53:43 933
12:53:43 934          --  If more than two values within M5-M1 are missing or are ∩┐╜999∩┐╜, no trend
12:53:43 935              IF  L_LAST5_SET<3
12:53:43 936          --  If more than one value within M3-M1 is missing or is ∩┐╜999∩┐╜, no trend
12:53:43 937              OR  L_LAST3_SET<2 THEN
12:53:43 938                    open o_cursor for select 1 from dual where 0=1;
12:53:43 939              RETURN ; end if;
12:53:43 940
12:53:43 941              -- X := the list of integers with values 1, 2, ∩┐╜ , n. Then
12:53:43 942
12:53:43 943                --trend value calculation:
12:53:43 944                WITH LATEST AS (
12:53:43 945                  SELECT DECODE(BALANCE_TOTAL,NULL,0,1) AS NON_EMPTY_BALANCE,BALANCE_TOTAL AS S,CPH.YYYY_MM,rownum as n
12:53:43 946                  FROM PAYMENT_HISTORY  CPH
12:53:43 947                    INNER JOIN
12:53:43 948                    (select v6.*, last_n_desc as last_n
12:53:43 949                      FROM V_LAST_6MONTHS V6
12:53:43 950                      order by yyyy_mm ASC) v6 ON (V6.YYYY_MM = CPH.YYYY_MM)
12:53:43 951                  WHERE SAFE_NUMBER = I_SAFE_NUMBER
12:53:43 952                  AND (LAST_N<=6 )
12:53:43 953                  AND BALANCE_total is not null
12:53:43 954                ),
12:53:43 955                AVERAGE AS (
12:53:43 956                    SELECT AVG(S) AS MEAN_S,
12:53:43 957                           AVG(N) AS MEAN_N,
12:53:43 958                           MAX(YYYY_MM) AS YYYY_MM
12:53:43 959                    from latest
12:53:43 960                )
12:53:43 961                -- here: ( ( S1*X1 + S2*X2 + ∩┐╜ +  SN*XN ) ∩┐╜ N*MEAN(X)MEAN(S) )/((N-1)*(SD(X)^2))
12:53:43 962                ,calc_trends as
12:53:43 963                (SELECT
12:53:43 964                      (CASE
12:53:43 965                      WHEN
12:53:43 966                        ((LATEST.N-1)* POWER(STDDEV(UPTO.N) ,2))<>0 --DIVIDER,
12:53:43 967                      THEN
12:53:43 968                         (SUM(UPTO.S*UPTO.N)-  LATEST.N * mean_n*mean_s)
12:53:43 969                          / ((LATEST.N-1)* POWER(STDDEV(UPTO.N) ,2))
12:53:43 970                      end)
12:53:43 971                                                                              AS TRENDVALUE,
12:53:43 972                        MEAN_S AS AVG_S,
12:53:43 973                        mean_n as avg_X
12:53:43 974                FROM LATEST
12:53:43 975                      INNER JOIN AVERAGE ON (LATEST.YYYY_MM = AVERAGE.YYYY_MM)
12:53:43 976                      LEFT OUTER JOIN LATEST UPTO ON (UPTO.NON_EMPTY_BALANCE = 1
12:53:43 977                                                      AND UPTO.N<=LATEST.N)
12:53:43 978                WHERE LATEST.NON_EMPTY_BALANCE = 1
12:53:43 979                GROUP BY LATEST.N,LATEST.YYYY_MM,MEAN_N,MEAN_S,LATEST.S -- this all is 1:1
12:53:43 980                  ORDER BY LATEST.YYYY_MM DESC)
12:53:43 981                --- y=Ax=B, calc A and B here
12:53:43 982                    SELECT round(TRENDVALUE ,2) as TRENDVALUE ,
12:53:43 983                           TRENDVALUE AS A,
12:53:43 984                           AVG_S-AVG_X*TRENDVALUE AS B
12:53:43 985                           into o_TREND_VALUE,  -- this value is returned as factor
12:53:43 986                                chart_a, chart_b
12:53:43 987                    from calc_trends;
12:53:43 988
12:53:43 989                  if (i_with_cursor!='Y') then return; end if;
12:53:43 990
12:53:43 991                  --- the returnes values is propagation over last 6 months:
12:53:43 992                 OPEN O_CURSOR FOR
12:53:43 993                  SELECT YYYY_MM,
12:53:43 994                        ROUND(CHART_A*(RANK() OVER (ORDER BY YYYY_MM ASC))+CHART_B,2) as trend,
12:53:43 995                        chart_A as A,
12:53:43 996                        chart_b AS B
12:53:43 997                  FROM V_LAST_6MONTHS
12:53:43 998                  ORDER BY YYYY_MM ASC;
12:53:43 999
12:53:43 1000                EXCEPTION
12:53:43 1001                 WHEN NO_DATA_FOUND THEN
12:53:43 1002                  open o_cursor for select 1 from dual where 0=1;
12:53:43 1003                  return;
12:53:43 1004              END;
12:53:43 1005
12:53:43 1006      end p_balance_TREND;
