12:53:43 1281      Procedure P_Get_Monthly_DBT_Trends  (
12:53:43 1282            I_SAFE_NUMBER IN VARCHAR2,
12:53:43 1283            I_ROWS_NUMBER NUMBER,
12:53:43 1284            O_CURSOR OUT SYS_REFCURSOR,
12:53:43 1285            o_cursor_industry out SYS_REFCURSOR
