12:53:44 1330      Procedure Get_Osha_Data
12:53:44 1331      (
12:53:44 1332        I_Safe_Number In Varchar2,
12:53:44 1333        O_Cursor OUT SYS_REFCURSOR
12:53:44 1334      )
12:53:44 1335      IS
12:53:44 1336      BEGIN
12:53:44 1337        OPEN O_Cursor FOR
12:53:44 1338          select * from (
12:53:44 1339            SELECT
12:53:44 1340            i.activity_nr,
12:53:44 1341            v.citation_id,
12:53:44 1342            i.site_address,
12:53:44 1343            v.initial_penalty,
12:53:44 1344            v.current_penalty,
12:53:44 1345            (SELECT viol_type_desc FROM DIC_osha_VIOL_TYPES dvt WHERE dvt.viol_type = v.viol_type) as Viol_Type_Desc ,
12:53:44 1346            v.nr_instances,
12:53:44 1347            v.abate_date,
12:53:44 1348            (SELECT abate_complete_desc from dic_osha_abate_completes dac WHERE dac.abate_complete=v.abate_complete) AS Abate_Complete_Desc,
12:53:44 1349            v.fta_penalty as Failure_To_Abate_Penalty,
12:53:44 1350            v.FTA_FINAL_ORDER_DATE,
12:53:44 1351            i.open_date,
12:53:44 1352            i.safety_hlth as Safety_Health,
12:53:44 1353            (SELECT insp_type_desc from dic_osha_inspection_types dit WHERE dit.insp_type=i.insp_type) AS Insp_Type_Desc,
12:53:44 1354            i.close_case_date as Close_Date
12:53:44 1355            FROM osha_inspection i
12:53:44 1356            LEFT OUTER JOIN osha_violation v on i.activity_nr = v.activity_nr and delete_flag is null
12:53:44 1357            WHERE i.safe_number = I_Safe_Number -- records matched to specific safe number
12:53:44 1358              and ((months_between(sysdate, i.close_case_date) < 36 or i.close_case_date is null) )-- records no older than 3 years
12:53:44 1359            order by i.close_case_date desc -- ordered by end date
12:53:44 1360            ,        v.citation_id asc nulls last -- secondary ordered by violation citation id
12:53:44 1361          ) where rownum < 51;
12:53:44 1362      END Get_Osha_Data;
