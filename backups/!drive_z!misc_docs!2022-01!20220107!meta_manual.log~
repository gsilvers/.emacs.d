12:53:43 1238                    FROM cs_stats_filings_history
12:53:43 1239                    WHERE SIC= I_SIC_TO_COMPARE
12:53:43 1240                  GROUP BY YYYY_MM) CORE ON (CORE.YYYY_mm=MONTHS.YYYY_MM)
12:53:43 1241              order by months.yyyy_mm asc;
12:53:43 1242
12:53:43 1243        end Get_Derogatory_Liablty_compare;
