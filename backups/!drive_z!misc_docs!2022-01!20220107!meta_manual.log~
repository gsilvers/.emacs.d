12:53:43 261                   round(core.value,2) as value
12:53:43 262              from v_last_6months MONTHS
12:53:43 263               LEFT OUTER JOIN
12:53:43 264         (Select
12:53:43 265
12:53:43 266              SU.YYYY_MM,
