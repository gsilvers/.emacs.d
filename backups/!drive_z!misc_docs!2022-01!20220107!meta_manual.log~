12:53:43 1032          PROCEDURE p_get_tpd_group_industries
12:53:43 1033         (
12:53:43 1034          i_safe_number IN VARCHAR2,
12:53:43 1035          o_cursor out sys_refcursor
12:53:43 1036        )
12:53:43 1037        IS
12:53:43 1038          l_orgnr_groupemother group_structure.orgnr_groupemother%TYPE;
12:53:43 1039          l_size_of_group NUMBER;
12:53:43 1040          l_group_trade_lines NUMBER;
12:53:43 1041        BEGIN
12:53:43 1042
12:53:43 1043         BEGIN
12:53:43 1044             SELECT MAX(gs.orgnr_groupemother)
12:53:43 1045             INTO l_orgnr_groupemother
12:53:43 1046             FROM group_structure gs
12:53:43 1047             WHERE gs.safe_number = i_safe_number;
12:53:43 1048
12:53:43 1049             SELECT count(gs.orgnr_daughter)
12:53:43 1050                   ,sum(ps.trade_lines)
12:53:43 1051             INTO l_size_of_group
12:53:43 1052                 ,l_group_trade_lines
12:53:43 1053             FROM group_structure gs
12:53:43 1054             LEFT OUTER JOIN payment ps
12:53:43 1055             ON (gs.safe_number = ps.safe_number)
12:53:43 1056             WHERE orgnr_groupemother = l_orgnr_groupemother;
12:53:43 1057          exception
12:53:43 1058            WHEN no_data_found THEN
12:53:43 1059              l_size_of_group:=0;
12:53:43 1060          END;
12:53:43 1061
12:53:43 1062         IF (l_size_of_group<=1)
12:53:43 1063         THEN
12:53:43 1064          -- empty response, not to show whole categor
12:53:43 1065          OPEN o_cursor FOR
12:53:43 1066          SELECT NULL AS group_is_empty FROM dual WHERE 0=1;
12:53:43 1067          RETURN;
12:53:43 1068         END IF;
12:53:43 1069
12:53:43 1070          OPEN o_cursor FOR
12:53:43 1071            WITH group_sums as
12:53:43 1072            (SELECT coalesce( p.industry_code, 'O' )  AS industry
12:53:43 1073                  ,MIN(initcap(p.description)) AS industry_description
12:53:43 1074                  ,sum(p.trade_lines) AS trade_lines
12:53:43 1075                  ,(CASE WHEN l_size_of_group <> 0
12:53:43 1076                     THEN round((sum(p.trade_lines)*100.)/l_group_trade_lines,2) END) AS pct_trade_lines
12:53:43 1077                  , sum(nvl(balance_current,0)) as balance_current-- on screen "current"
12:53:43 1078                  , sum(nvl(balance_1_30,0)) as balance_1_30-- on screen "1-30"
12:53:43 1079                  , sum(nvl(balance_31_60,0)) as balance_31_60-- on screen "31-60"
12:53:43 1080                  , sum(nvl(balance_61_90,0)) as balance_61_90-- on screen "61-90"
12:53:43 1081                  , sum(nvl(p.balance_91plus,0)) as balance_91plus-- on screen "90+"
12:53:43 1082                  , sum(nvl(balance_current,0)) + sum(nvl(balance_1_30,0)) + sum(nvl(balance_31_60,0)) + sum(nvl(balance_61_90,0)) + sum(nvl(balance_91plus,0)) AS balance_total
12:53:43 1083                  FROM payment_industry p INNER JOIN group_structure gs ON (p.safe_number = gs.safe_number)
12:53:43 1084                  WHERE gs.orgnr_groupemother = l_orgnr_groupemother
12:53:43 1085                  GROUP BY p.industry_code)
12:53:43 1086              select group_sums.industry as industry
12:53:43 1087                  , group_sums.industry_description as industry_description
12:53:43 1088                  , group_sums.trade_lines as trade_lines
12:53:43 1089                  , group_sums.pct_trade_lines as pct_trade_lines
12:53:43 1090                  , group_sums.balance_current as balance_current
12:53:43 1091                  , group_sums.balance_1_30 as balance_1_30
12:53:43 1092                  , group_sums.balance_31_60 as balance_31_60
12:53:43 1093                  , group_sums.balance_61_90 as balance_61_90
12:53:43 1094                  , group_sums.balance_91plus as balance_91plus
12:53:43 1095                  , group_sums.balance_total as balance_total
12:53:43 1096                  , CASE WHEN group_sums.balance_total<>0 THEN
12:53:43 1097                          ROUND((group_sums.balance_current / DECODE(group_sums.balance_total,0,1,group_sums.balance_total)) * 100,2)
