12:53:43 1184   PROCEDURE p_get_dbt_range_comparision(i_safe_number  VARCHAR2
12:53:43 1185                                            ,o_cursor       OUT SYS_REFCURSOR) IS
12:53:43 1186         l_max_yyyymm  cs_stats_dbt_range.yyyy_mm%TYPE;
12:53:43 1187         l_dbt         v_payment.dbt%TYPE;
12:53:43 1188       BEGIN
12:53:43 1189         SELECT MAX(yyyy_mm)
12:53:43 1190         INTO l_max_yyyymm
12:53:43 1191         FROM cs_stats_dbt_range;
12:53:43 1192
12:53:43 1193         SELECT MAX(dbt)
12:53:43 1194         INTO l_dbt
12:53:43 1195         FROM v_payment
12:53:43 1196         WHERE safe_number = i_safe_number;
12:53:43 1197
12:53:43 1198         OPEN o_cursor FOR
12:53:43 1199         WITH
12:53:43 1200          v_stats_dbt_count AS
12:53:43 1201           (SELECT dc.number_of_companies
12:53:43 1202            FROM cs_stats_dbt_count dc
12:53:43 1203            WHERE (dc.yyyy_mm = l_max_yyyymm) AND (dc.dbt = l_dbt))
12:53:43 1204         ,v_stats_dbt_range AS
12:53:43 1205          (
12:53:43 1206           SELECT SUM(cp.dbt_0)                  AS dbt_0
12:53:43 1207                   ,SUM(cp.dbt_1_30)             AS dbt_1_30
12:53:43 1208                   ,SUM(cp.dbt_31_60)            AS dbt_31_60
12:53:43 1209                   ,SUM(cp.dbt_61_90)            AS dbt_61_90
12:53:43 1210                   ,SUM(cp.dbt_over_90)          AS dbt_over_90
12:53:43 1211                   ,nvl(SUM(cp.dbt_0), 0)
12:53:43 1212                   + nvl(SUM(cp.dbt_1_30), 0)
12:53:43 1213                   + nvl(SUM(cp.dbt_31_60), 0)
12:53:43 1214                   + nvl(SUM(cp.dbt_61_90), 0)
12:53:43 1215                   + nvl(SUM(cp.dbt_over_90), 0) AS total_companies
12:53:43 1216              FROM cs_stats_dbt_range cp
12:53:43 1217              WHERE (cp.yyyy_mm = l_max_yyyymm))
12:53:43 1218           SELECT vdr.*
12:53:43 1219                 ,vdc.number_of_companies AS companies_with_same_dbt
12:53:43 1220           FROM v_stats_dbt_range vdr
12:53:43 1221           LEFT JOIN v_stats_dbt_count vdc ON (1=1);
12:53:43 1222       END  p_get_dbt_range_comparision;
