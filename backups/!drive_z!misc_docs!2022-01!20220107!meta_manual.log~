12:53:43 1294
12:53:43 1295          select max(yyyy_mm) into max_yyyy_mm from V_LAST_13MONTHS_CURR;
12:53:43 1296
12:53:43 1297          select count(*) into curr_trade from PAYMENT_HISTORY
12:53:43 1298              where yyyy_mm = max_yyyy_mm and safe_number = i_safe_number;
12:53:43 1299
12:53:43 1300        if curr_trade = 0
12:53:43 1301          then
12:53:43 1302           upper_lim := 13;
12:53:43 1303           lower_lim := 2 ;
12:53:43 1304        else
12:53:43 1305           upper_lim := 12;
12:53:43 1306           lower_lim := 1 ;
12:53:43 1307        end if;
12:53:43 1308
12:53:43 1309            OPEN O_CURSOR FOR
12:53:43 1310            SELECT  coalesce(his.yyyy_mm,v12.yyyy_mm) as DBT_DATE,
12:53:43 1311                    DBT,
12:53:43 1312                    v12.yyyy_mm,
