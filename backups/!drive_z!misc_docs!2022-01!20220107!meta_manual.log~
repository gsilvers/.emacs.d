12:53:43 1245        procedure get_sam_gov_data(
12:53:43 1246            I_Safe_Number In Varchar2,--try for US22384484
12:53:43 1247            O_CURSOR OUT SYS_REFCURSOR
12:53:43 1248        )
12:53:43 1249        is
12:53:43 1250          any_active number;
12:53:43 1251        begin
12:53:43 1252
12:53:43 1253          select count(*)  into any_active
12:53:43 1254            from sam_gov_monthly sam
12:53:43 1255          where sam.safe_number= I_Safe_Number
12:53:43 1256          and sam.sam_extract_code = 'A'--(A = active, E = expired).
12:53:43 1257          and rownum=1;
12:53:43 1258
12:53:43 1259          if any_active=0
12:53:43 1260          then
12:53:43 1261          -- look for excluded:
12:53:43 1262            Open O_Cursor For
12:53:43 1263                Select -- intentionally nulls, as no program because subject is excluded from any
12:53:43 1264                     null as Gov_Contract_Participant,
12:53:43 1265                     null as Gov_Contract_Date,
12:53:43 1266                     null as Gov_Grant_Recipient,
12:53:43 1267                     null as Gov_Grant_Date,
12:53:43 1268                     null as Gov_Loan_Recipient ,
12:53:43 1269                     null as Loan_date , ---!!!!!!!!!!!!!!!!!!!!!!
12:53:43 1270                     'Y' As Gov_Exclusion ,
12:53:43 1271                     excl.Termination_Date as Termination_date ,
12:53:43 1272                     null as Adminstrative_Debt ,
12:53:43 1273                     null as  Labor_Surplus_Area ,
12:53:43 1274                      ----------SBA---------------
12:53:43 1275                      null as  Sba_Certified_HubZone ,
12:53:43 1276                      null as Sba_Certified_Business ,
12:53:43 1277                      null as  Sba_Certified_Business_date ,
12:53:43 1278                     null as Sba_Certified_8A_Program ,
12:53:43 1279                     null as Sba_Certfied_8A_Program_Date
12:53:43 1280              from  sam_gov_excluded excl
12:53:43 1281                where excl.classification in ('Firm','Special Entity Designation')
12:53:43 1282                and excl.safe_number = I_Safe_Number
12:53:43 1283                and rownum=1;
12:53:43 1284
12:53:43 1285            return;
12:53:43 1286          end if;-- look for excluded as no active matches
12:53:43 1287
12:53:43 1288            open o_cursor for
12:53:43 1289            with excluded as
12:53:43 1290              (select 1 as excluded, excl.Termination_Date,excl.duns,excl.safe_number
12:53:43 1291                from  sam_gov_excluded excl
12:53:43 1292                where excl.classification in ('Firm','Special Entity Designation')
12:53:43 1293                and excl.safe_number= I_Safe_Number
12:53:43 1294                and rownum=1
12:53:43 1295               )
12:53:43 1296
12:53:43 1297            select
12:53:43 1298                 (case when sam.bus_type_string like '%VW%'   then 'Y' else 'N' end) as Gov_Contract_Participant,
12:53:43 1299                  (case when sam.bus_type_string like '%VW%'   then sam.ACTIVATION_DATE  end) as Gov_Contract_Date ,---!!!!!!!!!!!!!!!!!!!!!!
12:53:43 1300                 -- LOAN:
12:53:43 1301                 (case when sam.bus_type_string like '%V2%'   then 'Y' else 'N' end) as Gov_Grant_Recipient,
12:53:43 1302                 (case when sam.bus_type_string like '%V2%'   then sam.activation_date  end) as Gov_Grant_Date ,---!!!!!!!!!!!!!!!!!!!!!!
12:53:43 1303                null as Gov_Loan_Recipient ,
12:53:43 1304                null as Loan_date , ---!!!!!!!!!!!!!!!!!!!!!!
12:53:43 1305                -- EXCLUSION:
12:53:43 1306              (case when nvl(ex.excluded,0)>0 then 'Y' else 'N' end) as Gov_Exclusion ,
12:53:43 1307              (case when nvl(ex.excluded,0)>0 then ex.Termination_Date end) as Termination_date ,
12:53:44 1308              (case when  sam.DELINQUENT_FEDERAL_DEBT_FLAG ='Y' then 'Y' else 'N' end) /*bool */ Adminstrative_Debt ,
12:53:44 1309              (case when bus_type_string like '%A3%'  then 'Y' else 'N' end) as /*bool*/ Labor_Surplus_Area ,
12:53:44 1310              ----------SBA---------------
12:53:44 1311              (case when sam.SBA_BUSINESS_TYPES_STRING like '%XX%'   then 'Y' else 'N' end) as /*bool*/ Sba_Certified_HubZone ,
12:53:44 1312              (case when sam.SBA_BUSINESS_TYPES_STRING like '%A4%'   then 'Y' else 'N' end) as /*bool*/ Sba_Certified_Business ,
12:53:44 1313              (case when sam.SBA_BUSINESS_TYPES_STRING like '%A4%'   then
12:53:44 1314                to_date(substr(SBA_BUSINESS_TYPES_STRING,instr(sam.SBA_BUSINESS_TYPES_STRING,'A4')+length('A4'),8),'YYYYMMDD') end) as  Sba_Certified_Business_date ,
12:53:44 1315              (case when sam.SBA_BUSINESS_TYPES_STRING like '%A6%'  or sam.SBA_BUSINESS_TYPES_STRING like '%JT%'   then 'Y' else 'N'end) as /*bool */Sba_Certified_8A_Program ,
12:53:44 1316              (case
12:53:44 1317                when sam.SBA_BUSINESS_TYPES_STRING like '%A6%'   then
12:53:44 1318                  to_date(substr(SBA_BUSINESS_TYPES_STRING,instr(sam.SBA_BUSINESS_TYPES_STRING,'A6')+length('A6'),8),'YYYYMMDD')
12:53:44 1319               when sam.SBA_BUSINESS_TYPES_STRING like '%JT%' then
12:53:44 1320                  to_date(substr(SBA_BUSINESS_TYPES_STRING,instr(sam.SBA_BUSINESS_TYPES_STRING,'JT')+length('JT'),8),'YYYYMMDD')
12:53:44 1321               end)  as  /*DateTime */Sba_Certfied_8A_Program_Date
12:53:44 1322        from sam_gov_monthly sam
12:53:44 1323             left outer join excluded ex on (sam.safe_number=ex.safe_number)
12:53:44 1324        where sam.Safe_Number= I_Safe_Number
12:53:44 1325        and sam.sam_extract_code = 'A'--(A = active, E = expired).
12:53:44 1326        and rownum=1;
12:53:44 1327
12:53:44 1328        end get_sam_gov_data;
