12:53:42 921                                          payment_val_made_in_91plus) <> 0 THEN
12:53:42 922                                          round(((SUM(payment_val_made_in_1_30) * 15) +(SUM(payment_val_made_in_31_60) * 45) +(SUM(payment_val_made_in_61_90) *
12:53:42 923                                          75) +(SUM(payment_val_made_in_91plus) * 105)) / SUM(payment_val_made_on_time + payment_val_made_in_1_30 +
12:53:42 924                                          payment_val_made_in_31_60 + payment_val_made_in_61_90 + payment_val_made_in_91plus))
