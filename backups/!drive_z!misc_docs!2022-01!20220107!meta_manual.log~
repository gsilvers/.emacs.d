12:53:43 1196      Procedure Get_Derogatory_Liablty_compare
12:53:43 1197       (
12:53:43 1198       I_STATE_TO_COMPARE IN VARCHAR2,
12:53:43 1199        I_SIC_TO_COMPARE IN VARCHAR2,
12:53:43 1200        --I_BusinessType_to_compare in varchar2,--not sure for use
12:53:43 1201        O_State_Cursor Out Sys_Refcursor,
12:53:43 1202        O_Industry_Cursor Out Sys_Refcursor
