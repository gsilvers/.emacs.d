12:53:43 1118   PROCEDURE p_get_tpd_industries(i_safe_number IN VARCHAR2
12:53:43 1119                                      ,o_cursor      OUT SYS_REFCURSOR) IS
12:53:43 1120        BEGIN
12:53:43 1121          OPEN o_cursor FOR
12:53:43 1122            WITH divisior AS
12:53:43 1123             (SELECT coalesce( industry_code, 'O' )  AS industry_code
12:53:43 1124                    ,nvl(balance_current, 0) + nvl(balance_1_30, 0) +
12:53:43 1125                     nvl(balance_31_60, 0) + nvl(balance_61_90, 0) +
12:53:43 1126                     nvl(balance_91plus, 0) AS divisior_balance_total
12:53:43 1127              FROM payment_industry p
12:53:43 1128              WHERE p.safe_number = i_safe_number),
12:53:43 1129            totals AS
12:53:43 1130             (SELECT nvl(SUM(trade_lines), 0) AS total_trade_lines
12:53:43 1131                    ,i_safe_number AS safe_number
12:53:43 1132              FROM payment_industry p
12:53:43 1133              WHERE p.safe_number = i_safe_number)
12:53:43 1134            SELECT p.trade_lines -- on screen: "trade"
12:53:43 1135                  ,(CASE
12:53:43 1136                     WHEN totals.total_trade_lines <> 0 THEN
12:53:43 1137                      round((p.trade_lines * 100.) / totals.total_trade_lines, 2)
12:53:43 1138                   END) AS pct_trade_lines
12:53:43 1139                  ,p.industry_code AS industry_code
12:53:43 1140                  ,initcap(p.description) AS industry_description
12:53:43 1141
12:53:43 1142                  ,p.balance_current -- on screen "current"
12:53:43 1143                  ,p.balance_1_30 -- on screen "1-30"
12:53:43 1144                  ,p.balance_31_60 -- on screen "31-60"
12:53:43 1145                  ,p.balance_61_90 -- on screen "61-90"
12:53:43 1146                  ,p.balance_91plus -- on screen "90+"
12:53:43 1147
12:53:43 1148                  ,divisior_balance_total AS balance_total
12:53:43 1149
12:53:43 1150                   --percentages:
12:53:43 1151                  ,(CASE
12:53:43 1152                     WHEN divisior_balance_total <> 0 THEN
12:53:43 1153                      round((p.balance_current * 100.) / divisior_balance_total, 2)
12:53:43 1154                   END) AS pct_balance_current
12:53:43 1155                  ,(CASE
12:53:43 1156                     WHEN divisior_balance_total <> 0 THEN
12:53:43 1157                      round((p.balance_1_30 * 100.) / divisior_balance_total, 2)
12:53:43 1158                   END) AS pct_balance_1_30
12:53:43 1159                  ,(CASE
12:53:43 1160                     WHEN divisior_balance_total <> 0 THEN
12:53:43 1161                      round((p.balance_31_60 * 100.) / divisior_balance_total, 2)
12:53:43 1162                   END) AS pct_balance_31_60
12:53:43 1163                  ,(CASE
12:53:43 1164                     WHEN divisior_balance_total <> 0 THEN
12:53:43 1165                      round((p.balance_61_90 * 100.) / divisior_balance_total, 2)
12:53:43 1166                   END) AS pct_balance_61_90
12:53:43 1167                  ,(CASE
12:53:43 1168                     WHEN divisior_balance_total <> 0 THEN
12:53:43 1169                      round(100 - ((p.balance_current * 100.) / divisior_balance_total)
12:53:43 1170                                - ((p.balance_1_30 * 100.) / divisior_balance_total)
12:53:43 1171                                - ((p.balance_31_60 * 100.) / divisior_balance_total)
12:53:43 1172                                - ((p.balance_61_90 * 100.) / divisior_balance_total), 2)
12:53:43 1173                   END) AS pct_balance_91plus -- rounded to be 100%
12:53:43 1174            FROM payment_industry p
12:53:43 1175            INNER JOIN divisior d
12:53:43 1176            ON (p.industry_code = d.industry_code)
12:53:43 1177            INNER JOIN totals
12:53:43 1178            ON (totals.safe_number = i_safe_number)
12:53:43 1179            WHERE p.safe_number = i_safe_number
12:53:43 1180            ORDER BY p.rank DESC;
12:53:43 1181
12:53:43 1182        END p_get_tpd_industries;
