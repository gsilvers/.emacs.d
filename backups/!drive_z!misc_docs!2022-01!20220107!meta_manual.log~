12:53:42  62
12:53:42  63          (I_safe_number varchar2,
12:53:42  64            i_with_cursor in char default 'N',
12:53:42  65            O_CURSOR OUT SYS_REFCURSOR,
12:53:42  66            o_trend_Value out number
12:53:42  67          )
12:53:42  68          is
12:53:42  69          /*
12:53:42  70                  Calculation for this is:
12:53:42  71
12:53:42  72          ∩┐╜  If more than two values within M5-M1 are missing or are ∩┐╜999∩┐╜, no trend
12:53:42  73          ∩┐╜  If more than one value within M3-M1 is missing or is ∩┐╜999∩┐╜, no trend
12:53:42  74          ∩┐╜  Let S be the subset of non-missing and non-∩┐╜999∩┐╜ values within M5-M1, n the number of values in M and x be the list of integers with values 1, 2, ∩┐╜ , n. Then
12:53:42  75
12:53:42  76          TrendValue := ( ( S1*x1 + S2*x2 + ∩┐╜ +  Sn*xn ) ∩┐╜ n*mean(x)mean(S) )/((n-1)*(sd(x)^2))
12:53:42  77
12:53:42  78          Here "sd" stands for the SQL function for the standard deviation of a given list of numbers
12:53:42  79          and
12:53:42  80
12:53:42  81          M1 ∩┐╜ DBT 1 Month prior,M2 ∩┐╜ DBT 2 Months prior ,M3 ∩┐╜ DBT 3 Months prior ,M4 ∩┐╜ DBT 4 Months prior ,M5 ∩┐╜ DBT 5 Months prior
12:53:42  82          */
12:53:42  83            L_LAST3_SET NUMBER;
12:53:42  84            L_LAST5_SET NUMBER;
12:53:42  85
12:53:42  86            chart_A number;
12:53:42  87            chart_B NUMBER;
12:53:42  88          begin
12:53:42  89
12:53:42  90
12:53:42  91               begin
12:53:42  92             -- checking how many non-empty values we have
12:53:42  93              WITH LATEST AS (
12:53:42  94                   SELECT DECODE(cph.DBT,NULL,0,1) AS NON_EMPTY_DBT,
12:53:42  95                          CPH.DBT,
12:53:42  96                          v6.YYYY_MM,
12:53:42  97                           row_number() over (order by v6.yyyy_mm desc) as rn
12:53:42  98                    FROM (SELECT YYYY_MM, LAST_N_DESC AS LAST_N
12:53:42  99                            FROM V_LAST_6MONTHS V6
12:53:42 100                            ORDER BY YYYY_MM DESC) V6
12:53:42 101                          LEFT OUTER JOIN
12:53:42 102                            PAYMENT_HISTORY  CPH ON (V6.YYYY_MM = CPH.YYYY_MM and cph.safe_number = i_safe_number)
12:53:42 103                    WHERE (LAST_N<=6)
12:53:42 104              )
12:53:42 105              SELECT
12:53:42 106                 SUM(CASE WHEN RN<=3 THEN NON_EMPTY_DBT END) NON_EMPTY_DBT_LAST3,
12:53:42 107                 SUM(CASE WHEN RN<=5 THEN NON_EMPTY_DBT END) NON_EMPTY_DBT_LAST5
12:53:42 108               INTO
12:53:42 109                 l_last3_set, l_last5_set
12:53:42 110              FROM latEST ;
12:53:42 111
12:53:42 112          --  If more than two values within M5-M1 are missing or are ∩┐╜999∩┐╜, no trend
12:53:42 113              IF  L_LAST5_SET<3
12:53:42 114          --  If more than one value within M3-M1 is missing or is ∩┐╜999∩┐╜, no trend
12:53:42 115              OR  L_LAST3_SET<2 THEN
12:53:42 116                    open o_cursor for select 'L_LAST3_SET<3  it is = '||L_LAST3_SET as error_message from dual where 0=1;
12:53:42 117              RETURN ; end if;
12:53:42 118
12:53:42 119              -- X := the list of integers with values 1, 2, ∩┐╜ , n. Then
12:53:42 120
12:53:42 121                --trend value calculation:
12:53:42 122                WITH LATEST AS (
12:53:42 123                  SELECT DECODE(DBT,NULL,0,1) AS NON_EMPTY_DBT,dbt AS S,CPH.YYYY_MM,rownum as n
12:53:42 124                  FROM PAYMENT_HISTORY  CPH
12:53:42 125                    INNER JOIN
12:53:42 126                    (select v6.*, last_n_desc as last_n
12:53:42 127                      FROM V_LAST_6MONTHS V6
12:53:42 128                      order by yyyy_mm ASC) v6 ON (V6.YYYY_MM = CPH.YYYY_MM)
12:53:42 129                  WHERE safe_number = i_safe_number
12:53:42 130                  AND (LAST_N<=6 )
12:53:42 131                  AND dbt is not null
12:53:42 132                ),
12:53:42 133                AVERAGE AS (
12:53:42 134                    SELECT AVG(S) AS MEAN_S,
12:53:42 135                           AVG(N) AS MEAN_N,
12:53:42 136                           MAX(YYYY_MM) AS YYYY_MM
12:53:42 137                    from latest
12:53:42 138                )
12:53:42 139                -- here: ( ( S1*X1 + S2*X2 + ∩┐╜ +  SN*XN ) ∩┐╜ N*MEAN(X)MEAN(S) )/((N-1)*(SD(X)^2))
12:53:42 140                ,calc_trends as
12:53:42 141                (SELECT
12:53:42 142                      (CASE
12:53:42 143                      WHEN
12:53:42 144                        ((LATEST.N-1)* POWER(STDDEV(UPTO.N) ,2))<>0 --DIVIDER,
12:53:42 145                      THEN
12:53:42 146                         (SUM(UPTO.S*UPTO.N)-  LATEST.N * mean_n*mean_s)
12:53:42 147                          / ((LATEST.N-1)* POWER(STDDEV(UPTO.N) ,2))
12:53:42 148                      end)
12:53:42 149                                                                              AS TRENDVALUE,
12:53:42 150                        MEAN_S AS AVG_S,
12:53:42 151                        mean_n as avg_X
12:53:42 152                FROM LATEST
12:53:42 153                      INNER JOIN AVERAGE ON (LATEST.YYYY_MM = AVERAGE.YYYY_MM)
12:53:42 154                      LEFT OUTER JOIN LATEST UPTO ON (UPTO.NON_EMPTY_DBT = 1
12:53:42 155                                                      AND UPTO.N<=LATEST.N)
12:53:42 156                WHERE LATEST.NON_EMPTY_DBT = 1
12:53:42 157                GROUP BY LATEST.N,LATEST.YYYY_MM,MEAN_N,MEAN_S,LATEST.S -- this all is 1:1
12:53:42 158                  ORDER BY LATEST.YYYY_MM DESC)
12:53:42 159                --- y=Ax=B, calc A and B here
12:53:42 160                    SELECT round(TRENDVALUE ,2) as TRENDVALUE ,
12:53:42 161                           TRENDVALUE AS A,
12:53:42 162                           AVG_S-AVG_X*TRENDVALUE AS B
12:53:42 163                           into o_TREND_VALUE,  -- this value is returned as factor
12:53:42 164                                chart_a, chart_b
12:53:42 165                    from calc_trends;
12:53:42 166
12:53:42 167                  if (i_with_cursor!='Y') then return; end if;
12:53:42 168
12:53:42 169                  --- the returnes values is propagation over last 6 months:
12:53:42 170                 OPEN O_CURSOR FOR
12:53:42 171                  SELECT YYYY_MM,
12:53:42 172                        ROUND(CHART_A*(RANK() OVER (ORDER BY YYYY_MM ASC))+CHART_B,2) as trend,
12:53:42 173                        chart_A as A,
12:53:42 174                        chart_b AS B
12:53:42 175                  FROM V_LAST_6MONTHS
12:53:42 176                  ORDER BY YYYY_MM ASC;
12:53:42 177
12:53:42 178                EXCEPTION
12:53:42 179                 WHEN NO_DATA_FOUND THEN
12:53:42 180                  open o_cursor for select 'no data found' from dual where 0=1;
12:53:42 181                  return;
12:53:42 182              END;
12:53:42 183
12:53:42 184      end p_DBT_TREND;
