12:53:43 1328                SELECT
12:53:43 1329                    v12.yyyy_mm,
12:53:43 1330                    DBT,
12:53:43 1331                    last_n,
12:53:43 1332                    "COUNT(*)"
12:53:43 1333              FROM (SELECT YYYY_MM, LAST_N_DESC AS LAST_N
12:53:43 1334                                  FROM V_LAST_13MONTHS_CURR V13
12:53:43 1335                                  ORDER BY YYYY_MM DESC
12:53:43 1336                                  ) V12
12:53:43 1337                      LEFT OUTER JOIN
12:53:43 1338                mv_sic4digs_dbt_averages  his ON (V12.YYYY_MM = his.YYYY_MM and SIC_FOUR_DIGITS = l_sic_4_digits and  his.yyyy_mm>=l_down_time_limit and "COUNT(*)" >1)
12:53:43 1339                where last_n between lower_lim and upper_lim
12:53:43 1340                order by v12.yyyy_mm, last_n;
